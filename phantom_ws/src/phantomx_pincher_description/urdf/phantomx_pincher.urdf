  <joint name="phantomx_pincher_base_link_joint" type="fixed">
    <parent link="phantomx_pincher_base_link"/>
    <!-- world_link es la raíz definida en kit.xacro -->
    <child link="world_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
