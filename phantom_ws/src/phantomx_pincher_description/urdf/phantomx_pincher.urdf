      <origin rpy="0.0 0.0 0.0" xyz="-7.38454e-07 0.000422614 -0.0130296"/>
      <mass value="0.08139802400654242"/>
      <inertia ixx="2.3143627968295997e-05" ixy="-6.904875516785507e-10" ixz="-2.4208698077741694e-10" iyy="1.9936031209683584e-05" iyz="3.504110421945422e-07" izz="1.2576986445925398e-05"/>
    </inertial>
  </link>
  <gazebo reference="phantomx_pincher_gripper_servo_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- Joint fijo que conecta el servo del gripper con la placa base.
       Desplazado 19 mm en Y (mitad del ancho del servo). -->
  <joint name="phantomx_pincher_gripper_finger_base_joint" type="fixed">
    <parent link="phantomx_pincher_gripper_servo_link"/>
    <child link="phantomx_pincher_gripper_finger_base_link"/>
    <origin rpy="3.141592653589793 0.0 1.5707963267948966" xyz="0 0.019 0.0"/>
  </joint>
  <!-- Placa base del gripper: estructura central que sostiene ambos dedos.
       Visual: gripper_base.dae. Colisión con caja de 2x75x40 mm. -->
  <link name="phantomx_pincher_gripper_finger_base_link">
    <visual>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://phantomx_pincher_description/meshes/visual/gripper_base.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.002 0.075 0.040"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="0 2.98023e-08 0"/>
      <mass value="0.011837674839899828"/>
      <inertia ixx="7.127260849628046e-06" ixy="3.400011875409145e-24" ixz="-0.0" iyy="1.5822994239366863e-06" iyz="-0.0" izz="5.5528530038746866e-06"/>
    </inertial>
  </link>
  <gazebo reference="phantomx_pincher_gripper_finger_base_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- Dedo 1 del gripper (lado izquierdo): articulación prismática
       que se traslada sobre X para abrir/cerrar el gripper.
       Límites medidos físicamente en el hardware real:
         lower = cerrado: 7.5 mm / 2 = 3.75 mm por dedo
         upper = abierto: 39.1 mm / 2 = 19.55 mm por dedo
       Visual: finger.dae. Colisión con la malla STL real. -->
  <joint name="phantomx_pincher_gripper_finger1_joint" type="prismatic">
    <parent link="phantomx_pincher_gripper_finger_base_link"/>
    <child link="phantomx_pincher_gripper_finger1_link"/>
    <origin rpy="1.5707963267948966 0.0 1.5707963267948966" xyz="0.019 0.0115 0.0"/>
    <axis xyz="1.0 0.0 0.0"/>
    <!-- Límites actualizados con valores medidos físicamente en el hardware real. -->
    <!-- lower = cerrado: 7.5 mm apertura total / 2 = 0.00375 m por dedo.        -->
    <!-- upper = abierto: 39.1 mm apertura total / 2 = 0.01955 m por dedo.       -->
    <!-- Deben coincidir con joint_limits.yaml y follow_joint_trajectory_node.py. -->
    <limit effort="30" lower="0.00375" upper="0.01955" velocity="0.01"/>
    <dynamics damping="1.8" friction="0.06"/>
  </joint>
  <gazebo reference="phantomx_pincher_gripper_finger1_joint">
    <springStiffness value="0.0"/>
    <springReference value="0.0"/>
  </gazebo>
  <link name="phantomx_pincher_gripper_finger1_link">
    <visual>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://phantomx_pincher_description/meshes/visual/finger.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://phantomx_pincher_description/meshes/collision/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="-0.00607194 -4.42132e-19 -0.00471261"/>
      <mass value="0.009843256743296712"/>
      <inertia ixx="1.8229100836948666e-06" ixy="-2.797502899373518e-23" ixz="3.498974201392864e-07" iyy="1.595545910676557e-06" iyz="4.770944797128244e-23" izz="1.0262210845211422e-06"/>
    </inertial>
  </link>
  <gazebo reference="phantomx_pincher_gripper_finger1_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- Dedo 2 del gripper (lado derecho): simétrico al dedo 1.
       Mismo servo, mismos límites. Origen desplazado en -Y
       para posicionarlo en el lado opuesto de la placa base. -->
  <joint name="phantomx_pincher_gripper_finger2_joint" type="prismatic">
    <parent link="phantomx_pincher_gripper_finger_base_link"/>
    <child link="phantomx_pincher_gripper_finger2_link"/>
    <origin rpy="1.5707963267948966 3.141592653589793 1.5707963267948966" xyz="0.019 -0.0115 0.0"/>
    <axis xyz="1.0 0.0 0.0"/>
    <!-- Mismos límites que finger1: ambos dedos son simétricos y usan el mismo servo. -->
    <limit effort="30" lower="0.00375" upper="0.01955" velocity="0.01"/>
    <dynamics damping="1.8" friction="0.06"/>
  </joint>
  <gazebo reference="phantomx_pincher_gripper_finger2_joint">
    <springStiffness value="0.0"/>
    <springReference value="0.0"/>
  </gazebo>
  <link name="phantomx_pincher_gripper_finger2_link">
    <visual>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://phantomx_pincher_description/meshes/visual/finger.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://phantomx_pincher_description/meshes/collision/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="-0.00607194 -4.42132e-19 -0.00471261"/>
      <mass value="0.009843256743296712"/>
      <inertia ixx="1.8229100836948666e-06" ixy="-2.797502899373518e-23" ixz="3.498974201392864e-07" iyy="1.595545910676557e-06" iyz="4.770944797128244e-23" izz="1.0262210845211422e-06"/>
    </inertial>
  </link>
  <gazebo reference="phantomx_pincher_gripper_finger2_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- ==================== -->
  <!-- Efector final        -->
  <!-- ==================== -->

  <!-- Link virtual sin geometría: punto de control TCP (Tool Center Point).
       MoveIt lo usa como referencia para calcular cinemática inversa.
       Desplazado 19 mm en X desde la placa base, al centro entre los dedos. -->
  <link name="phantomx_pincher_end_effector">
  </link>
  <joint name="phantomx_pincher_end_effector_virtual_joint" type="fixed">
    <parent link="phantomx_pincher_gripper_finger_base_link"/>
    <child link="phantomx_pincher_end_effector"/>
    <origin rpy="1.5707963267948966 -1.5707963267948966 1.5707963267948966" xyz="0.019 0.0 0.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- ROS 2 Control                                                -->
  <!-- Configuración del controlador en modo simulación fake        -->
  <!-- (mock_components/GenericSystem para ROS2 Jazzy).             -->
  <!-- Expone las interfaces de posición para las 4 articulaciones  -->
  <!-- del brazo y las 2 del gripper.                               -->
  <!-- ============================================================ -->
  <ros2_control name="phantomx_pincher_ros2_control_system" type="system">
    <hardware>
      <!-- Plugin de simulación en memoria para ROS2 Jazzy.
           fake_sensor_commands=true permite escribir estados directamente. -->
      <plugin>mock_components/GenericSystem</plugin>
      <param name="fake_sensor_commands">true</param>
    </hardware>

    <!-- Articulaciones del brazo: posición inicial 0.0 rad (posición home) -->
    <joint name="phantomx_pincher_arm_shoulder_pan_joint">
      <param name="initial_position">0.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="phantomx_pincher_arm_shoulder_lift_joint">
      <param name="initial_position">0.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="phantomx_pincher_arm_elbow_flex_joint">
      <param name="initial_position">0.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="phantomx_pincher_arm_wrist_flex_joint">
      <param name="initial_position">0.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Articulaciones del gripper: posición inicial 0.001 m (1 mm de apertura).
         El initial_value en state_interface es el valor que GenericSystem
         usa realmente; evita que el gripper arranque completamente cerrado. -->
    <joint name="phantomx_pincher_gripper_finger1_joint">
      <param name="initial_position">0.001</param>
      <command_interface name="position"/>
      <state_interface name="position">
        <!-- IMPORTANT: this is what GenericSystem actually uses -->
        <param name="initial_value">0.001</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="phantomx_pincher_gripper_finger2_joint">
      <param name="initial_position">0.001</param>
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.001</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ============================================================ -->
  <!-- Montaje alternativo (comentado)                             -->
  <!-- Cadena task_board → task_board_mount → base_mount → brazo.  -->
  <!-- No activo porque el brazo se monta sobre la plataforma KIT. -->
  <!-- ============================================================ -->
  <!--
  <xacro:task_board
      prefix="$(arg prefix)"
      child="task_board_mount_link"
      collision="$(arg collision)"
      gazebo_preserve_fixed_joint="$(arg gazebo_preserve_fixed_joint)"/>

  <xacro:task_board_mount
      prefix="$(arg prefix)"
      child="base_mount_link"
      collision="$(arg collision)"
      gazebo_preserve_fixed_joint="$(arg gazebo_preserve_fixed_joint)"/>

  <xacro:base_mount
      prefix="$(arg prefix)"
      child="arm_base_link"
      collision="$(arg collision)"
      gazebo_preserve_fixed_joint="$(arg gazebo_preserve_fixed_joint)"/>
  -->

  <!-- ============================================================ -->
  <!-- Plugin de Gazebo para ros2_control (comentado)             -->
  <!-- Solo necesario cuando el plugin es 'ign' o 'gz'.           -->
  <!-- No activo porque Gazebo no se usa en la Raspberry Pi 5.    -->
  <!-- ============================================================ -->
  <!-- Gazebo - ROS 2 control (Ignition)
  <xacro:if value="$(arg ros2_control)">
    <xacro:if value="${'ign' in '$(arg ros2_control_plugin)' or 'gz' in '$(arg ros2_control_plugin)'}">
      <xacro:ign_ros2_control controller_parameters="$(arg ros2_controller_parameters)"/>
    </xacro:if>
  </xacro:if>
  -->
</robot>
