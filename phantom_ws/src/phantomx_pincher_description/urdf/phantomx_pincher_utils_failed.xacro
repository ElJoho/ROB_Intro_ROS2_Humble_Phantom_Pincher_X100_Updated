<?xml version="1.0"?>
<!-- Macros utilitarios genéricos reutilizados por todo el modelo del brazo -->
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ============================================================ -->
  <!-- Archivo importado                                            -->
  <!-- Se cargan los datos de inercia de cada pieza. Esos valores   -->
  <!-- son necesarios para la simulación física (cálculo de masas,  -->
  <!-- centros de gravedad y tensores de inercia de cada link).     -->
  <!-- ============================================================ -->
  <xacro:include filename="$(find phantomx_pincher_description)/urdf/phantomx_pincher_inertial.xacro"/>


  <!-- ============================================================ -->
  <!-- Valores por defecto                                          -->
  <!-- Constantes auxiliares usadas como valor predeterminado en    -->
  <!-- parámetros opcionales de los macros. Evitan repetir "0 0 0"  -->
  <!-- o cadenas vacías en cada llamada.                            -->
  <!-- ============================================================ -->
  <xacro:property name="default_string"  value=""/>           <!-- Cadena vacía por defecto -->
  <xacro:property name="default_vector3" value="0.0 0.0 0.0"/> <!-- Vector nulo por defecto (xyz o rpy) -->
  <xacro:property name="PI" value="3.141592653589793" />

  <!-- ============================================================ -->
  <!-- Macro: phantomx_pincher_link                                 -->
  <!-- Crea un link URDF completo con visual, colisión e inercia.   -->
  <!-- Es el bloque fundamental usado por todos los componentes del  -->
  <!-- brazo. Cada servo, bracket y dedo lo llama con su malla y    -->
  <!-- tipo de colisión correspondiente.                            -->
  <!--                                                              -->
  <!-- Parámetros:                                                  -->
  <!--   link_name             : nombre del link                    -->
  <!--   mesh                  : nombre base del archivo de malla   -->
  <!--                           (sin extensión ni ruta)            -->
  <!--   visual                : activa/desactiva la geometría visual-->
  <!--   collision             : activa/desactiva la colisión        -->
  <!--   collision_type        : 'mesh' usa el .stl de colisión;    -->
  <!--                           'box' usa una caja aproximada      -->
  <!--   collision_box_size    : tamaño de la caja si collision_type -->
  <!--                           es 'box' (x y z en metros)         -->
  <!--   mesh_offset_visual_xyz/rpy    : posición y orientación     -->
  <!--                                   del visual respecto al link -->
  <!--   mesh_offset_collision_xyz/rpy : posición y orientación     -->
  <!--                                   de la colisión             -->
  <!--   mesh_offset_inertial_rpy      : orientación del tensor de  -->
  <!--                                   inercia                    -->
  <!--   mu                    : coeficiente de fricción de Gazebo   -->
  <!-- ============================================================ -->
  <xacro:macro name="phantomx_pincher_link" params="
    link_name
    mesh
    visual:=true
    collision:=true
    collision_type:=mesh
    collision_box_size:=${default_vector3}
    mesh_offset_visual_xyz:=${default_vector3}
    mesh_offset_visual_rpy:=${default_vector3}
    mesh_offset_collision_xyz:=${default_vector3}
    mesh_offset_collision_rpy:=${default_vector3}
    mesh_offset_inertial_rpy:=${default_vector3}
    mu:=1.0
  ">
    <link name="${link_name}">

      <!-- Geometría visual: carga el archivo .dae desde meshes/visual/ -->
      <visual>
        <origin xyz="${mesh_offset_visual_xyz}" rpy="${mesh_offset_visual_rpy}"/>
        <geometry>
          <mesh filename="package://phantomx_pincher_description/meshes/visual/${mesh}.dae"/>
        </geometry>
      </visual>

      <!-- Geometría de colisión: solo se añade si collision=true.
           Puede ser la malla .stl real (más precisa) o una caja
           aproximada (más rápida para la simulación). -->
      <xacro:if value="${collision}">
        <collision>
          <origin xyz="${mesh_offset_collision_xyz}" rpy="${mesh_offset_collision_rpy}"/>
          <geometry>
            <!-- Colisión con malla: usa el .stl de meshes/collision/ -->
            <xacro:if value="${collision_type == 'mesh'}">
              <mesh filename="package://phantomx_pincher_description/meshes/collision/${mesh}.stl"/>
            </xacro:if>
            <!-- Colisión con caja: más eficiente en simulación -->
            <xacro:if value="${collision_type == 'box'}">
              <box size="${collision_box_size}"/>
            </xacro:if>
          </geometry>
        </collision>
      </xacro:if>

      <!-- Propiedades inerciales: masa y tensor de inercia del link,
           cargados desde phantomx_pincher_inertial.xacro. -->
      <xacro:phantomx_pincher_inertial mesh="${mesh}" mesh_offset_rpy="${mesh_offset_inertial_rpy}"/>

    </link>

    <!-- Coeficiente de fricción para Gazebo (mu1 y mu2 son fricción
         estática y dinámica respectivamente en el simulador). -->
    <gazebo reference="${link_name}">
      <mu1 value="${mu}"/>
      <mu2 value="${mu}"/>
    </gazebo>
  </xacro:macro>


  <!-- ============================================================ -->
  <!-- Macro: phantomx_pincher_joint                                -->
  <!-- Crea un joint URDF completo entre dos links. Es el macro más  -->
  <!-- genérico del modelo: soporta joints fijos, giratorios,       -->
  <!-- prismáticos y continuos. Incluye validación, límites,        -->
  <!-- dinámica, mimic y parámetros opcionales de Gazebo.           -->
  <!--                                                              -->
  <!-- Parámetros principales:                                      -->
  <!--   parent/child          : links que conecta el joint         -->
  <!--   joint_name            : nombre del joint                   -->
  <!--   joint_type            : 'fixed', 'revolute', 'prismatic'   -->
  <!--                           o 'continuous'                     -->
  <!--   joint_origin_xyz/rpy  : posición y orientación del joint   -->
  <!--                           respecto al link padre             -->
  <!--   joint_axis_xyz        : eje de movimiento (no aplica en    -->
  <!--                           joints fijos)                      -->
  <!--   joint_lower/upper_limit : rango de movimiento              -->
  <!--   joint_velocity_limit  : velocidad máxima                   -->
  <!--   joint_torque_limit    : esfuerzo/fuerza máximos            -->
  <!--   joint_damping         : amortiguamiento de la dinámica     -->
  <!--   joint_friction        : fricción de la dinámica            -->
  <!--   mimic_joint           : si se indica, este joint imita el  -->
  <!--                           movimiento del joint especificado  -->
  <!--   safety_limits         : activa un controlador de seguridad  -->
  <!--                           con márgenes suaves antes del límite-->
  <!--   gazebo_spring_stiffness/reference : rigidez y referencia   -->
  <!--                           del resorte virtual en Gazebo      -->
  <!--   gazebo_preserve_fixed_joint : evita que Gazebo fusione este -->
  <!--                           joint fijo con su link padre        -->
  <!-- ============================================================ -->
  <xacro:macro name="phantomx_pincher_joint" params="
    parent
    child
    joint_name
    joint_type
    joint_origin_xyz
    joint_origin_rpy
    joint_axis_xyz:=unset
    joint_lower_limit:=unset
    joint_upper_limit:=unset
    joint_velocity_limit:=unset
    joint_torque_limit:=unset
    joint_damping:=0.0
    joint_friction:=0.0
    mimic_joint:=none
    safety_limits:=false
    safety_position_margin:=0.0
    safety_k_position:=0.0
    safety_k_velocity:=0.0
    gazebo_spring_stiffness:=0.0
    gazebo_spring_reference:=0.0
    gazebo_preserve_fixed_joint:=false
  ">

    <!-- Validación en tiempo de compilación: si el joint no es fijo,
         todos los parámetros de movimiento son obligatorios.
         Si alguno falta, xacro lanzará un error de nombre indefinido
         que detiene la compilación del URDF. -->
    <xacro:unless value="${joint_type == 'fixed'}">
      <xacro:if value="${joint_axis_xyz == 'unset'}">
        <xacro:ERROR_joint_axis_xyz_undefined/>
      </xacro:if>
      <xacro:if value="${joint_lower_limit == 'unset'}">
        <xacro:ERROR_joint_lower_limit_undefined/>
      </xacro:if>
      <xacro:if value="${joint_upper_limit == 'unset'}">
        <xacro:ERROR_joint_upper_limit_undefined/>
      </xacro:if>
      <xacro:if value="${joint_velocity_limit == 'unset'}">
        <xacro:ERROR_joint_velocity_limit_undefined/>
      </xacro:if>
      <xacro:if value="${joint_torque_limit == 'unset'}">
        <xacro:ERROR_joint_torque_limit_undefined/>
      </xacro:if>
    </xacro:unless>

    <joint name="${joint_name}" type="${joint_type}">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${joint_origin_xyz}" rpy="${joint_origin_rpy}"/>

      <!-- Los siguientes elementos solo aplican a joints no fijos -->
      <xacro:unless value="${joint_type == 'fixed'}">
        <axis xyz="${joint_axis_xyz}"/>

        <!-- Joints continuos (sin límites angulares) solo necesitan
             esfuerzo y velocidad máximos -->
        <xacro:if value="${joint_type == 'continuous'}">
          <limit effort="${joint_torque_limit}" velocity="${joint_velocity_limit}"/>
        </xacro:if>

        <!-- Joints giratorios y prismáticos sí tienen límites de rango -->
        <xacro:unless value="${joint_type == 'continuous'}">
          <limit lower="${joint_lower_limit}" upper="${joint_upper_limit}" effort="${joint_torque_limit}" velocity="${joint_velocity_limit}"/>
        </xacro:unless>

        <!-- Controlador de seguridad opcional: añade límites suaves
             antes de los límites físicos para proteger el hardware -->
        <xacro:if value="${safety_limits}">
          <safety_controller
              soft_lower_limit="${joint_lower_limit+safety_position_margin}"
              soft_upper_limit="${joint_upper_limit-safety_position_margin}"
              k_position="${safety_k_position}"
              k_velocity="${safety_k_velocity}"/>
        </xacro:if>

        <!-- Parámetros de dinámica: amortiguamiento y fricción del joint -->
        <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
      </xacro:unless>

      <!-- Si se especifica mimic_joint, este joint copia el movimiento
           del joint indicado (usado en el dedo 2 del gripper en simulación) -->
      <xacro:unless value="${mimic_joint == 'none'}">
        <mimic joint="${mimic_joint}"/>
      </xacro:unless>
    </joint>

    <!-- Resorte virtual en Gazebo para joints no fijos.
         Con los valores por defecto (0.0) no tiene efecto;
         se puede activar para simular elasticidad en un joint. -->
    <xacro:unless value="${joint_type == 'fixed'}">
      <gazebo reference="${joint_name}">
        <springStiffness value="${gazebo_spring_stiffness}"/>
        <springReference value="${gazebo_spring_reference}"/>
      </gazebo>
    </xacro:unless>

    <!-- Evita que Gazebo fusione este joint fijo con el link padre
         durante la conversión a SDF. Útil cuando se necesita que el
         link hijo sea independiente en el simulador. -->
    <xacro:if value="${joint_type == 'fixed' and gazebo_preserve_fixed_joint}">
      <gazebo reference="${joint_name}">
        <preserveFixedJoint>true</preserveFixedJoint>
        <disableFixedJointLumping>true</disableFixedJointLumping>
      </gazebo>
    </xacro:if>
  </xacro:macro>


  <!-- ============================================================ -->
  <!-- Macro: phantomx_pincher_virtual_link                         -->
  <!-- Crea un link virtual (sin geometría ni masa) conectado por   -->
  <!-- un joint fijo a un link padre. Se usa exclusivamente para    -->
  <!-- el efector final (end_effector): un punto de referencia en   -->
  <!-- el espacio que MoveIt usa para calcular la cinemática inversa.-->
  <!-- No tiene representación visual ni física.                    -->
  <!-- ============================================================ -->
  <xacro:macro name="phantomx_pincher_virtual_link" params="
    parent
    link_name
    joint_origin_xyz
    joint_origin_rpy
    gazebo_preserve_fixed_joint:=true
    visual_mesh:=none
    collision_mesh:=none
  ">
    <!-- Crea el link vacío mediante el macro dummy -->
    <xacro:phantomx_pincher_dummy_link
        link_name="${link_name}"
        gazebo_preserve_fixed_joint="${gazebo_preserve_fixed_joint}"
        visual_mesh="${visual_mesh}"
        collision_mesh="${collision_mesh}"/>

    <!-- Joint fijo que posiciona el punto virtual respecto al link padre -->
    <joint name="${link_name}_virtual_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${link_name}"/>
      <origin xyz="${joint_origin_xyz}" rpy="${joint_origin_rpy}"/>
    </joint>
  </xacro:macro>


  <!-- ============================================================ -->
  <!-- Macro: phantomx_pincher_dummy_link                           -->
  <!-- Crea un link vacío sin geometría visual ni de colisión.      -->
  <!-- Se usa en dos situaciones:                                   -->
  <!--   1. Como link base del brazo (punto de anclaje al mundo).   -->
  <!--   2. Como link del efector final (punto de control virtual). -->
  <!--                                                              -->
  <!-- Cuando gazebo_preserve_fixed_joint=true, se le añade una     -->
  <!-- inercia mínima (1e-5 kg) para que Gazebo no lo elimine al    -->
  <!-- convertir el URDF a SDF. Sin inercia, Gazebo fusionaría      -->
  <!-- este link con su padre y el joint desaparecería.             -->
  <!-- ============================================================ -->
  <xacro:macro name="phantomx_pincher_dummy_link"
      params="link_name collision:=false gazebo_preserve_fixed_joint:=false
            visual_mesh:=none
            collision_mesh:=none
            "
  >
    <link name="${link_name}">
      <!-- Inercia mínima ficticia: solo se añade cuando Gazebo necesita
           que el link exista como entidad independiente en la simulación.
           Los valores son prácticamente cero para no afectar la dinámica. -->
      <xacro:if value="${gazebo_preserve_fixed_joint}">
        <inertial>
          <mass value="1e-5"/>
          <inertia ixx="1e-35" iyy="1e-35" izz="1e-35" ixy="0.0" ixz="0.0" iyz="0.0"/>
        </inertial>
      </xacro:if>
  

    <!-- Visual opcional: solo se añade si se pasa un nombre de malla -->
    <xacro:unless value="${visual_mesh == 'none'}">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://phantomx_pincher_description/meshes/DAE/${visual_mesh}.dae"
          scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
    </xacro:unless>

    <!-- Colisión opcional: solo se añade si se pasa un nombre de malla -->
    <xacro:unless value="${collision_mesh == 'none'}">
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://phantomx_pincher_description/meshes/STL/${collision_mesh}.stl"
          scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
    </xacro:unless>

    </link>

  

    <!-- Indica a Gazebo que conserve el joint fijo asociado a este link
         y no lo fusione con el link padre durante la conversión a SDF. -->
    <xacro:if value="${gazebo_preserve_fixed_joint}">
      <gazebo reference="${link_name}_virtual_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
        <disableFixedJointLumping>true</disableFixedJointLumping>
      </gazebo>
    </xacro:if>
  </xacro:macro>

</robot>
<!--
pkill -f robot_state_publisher; pkill -f rviz2; pkill -f joint_state_publisher; ros2 launch urdf_tutorial display.launch.py model:=/home/unpi/ros2/KIT_Phantom_X_Pincher_ROS2/phantom_ws/src/phantomx_pincher_description/urdf/phantomx_pincher.urdf.xacro

 -->